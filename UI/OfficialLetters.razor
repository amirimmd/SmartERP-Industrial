@page "/letters"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext

<div class="module-header">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
        <div>
            <h1 style="color: var(--primary-color); font-weight: 800; font-size: 1.8rem; margin-bottom: 0.5rem;">دبیرخانه و نامه‌های رسمی</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.95rem;">بایگانی نامه‌های اداری و استعلامات</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">ایجاد نامه جدید</button>
    </div>

    <div class="card" style="padding: 0; overflow-x: auto;">
        <table class="industrial-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="padding: 1rem 1.5rem; text-align: right;">شماره نامه</th>
                    <th style="padding: 1rem 1.5rem; text-align: right;">موضوع نامه</th>
                    <th style="padding: 1rem 1.5rem; text-align: right;">گیرنده</th>
                    <th style="padding: 1rem 1.5rem; text-align: right;">تاریخ صدور</th>
                    <th style="padding: 1rem 1.5rem; text-align: center;">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="5" style="padding: 3rem; text-align: center;"><div class="loader-pulse-ring" style="margin: 0 auto;"></div></td></tr>
                }
                else if (!letters.Any())
                {
                    <tr><td colspan="5" style="padding: 4rem 2rem; text-align: center; color: var(--text-muted);"><p>دبیرخانه خالی است.</p></td></tr>
                }
                else
                {
                    @foreach (var l in letters)
                    {
                        <tr class="table-row-hover">
                            <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: var(--primary-color); font-weight: bold;">@l.LetterNumber</td>
                            <td style="padding: 1rem 1.5rem; color: var(--text-main); font-weight: bold;">@l.Subject</td>
                            <td style="padding: 1rem 1.5rem; color: var(--text-muted);">@l.Recipient</td>
                            <td style="padding: 1rem 1.5rem; font-family: var(--font-en);">@l.IssueDate.ToString("yyyy/MM/dd")</td>
                            <td style="padding: 1rem 1.5rem; text-align: center;">
                                <button style="background: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-main); cursor: pointer; padding: 0.4rem 0.8rem; border-radius: var(--radius-md); font-weight: bold; margin-left: 0.5rem;" @onclick="() => ViewLetter(l)">مشاهده</button>
                                <button style="background: none; border: none; color: var(--danger); cursor: pointer; padding: 0.5rem;" @onclick="() => DeleteLetter(l)">حذف</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (isModalOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(9, 9, 11, 0.9); z-index: 100; display: flex; align-items: center; justify-content: center;">
        <div class="card" style="width: 100%; max-width: 800px; border-top: 3px solid var(--primary-color);">
            <div style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
                <h2 style="font-size: 1.3rem; color: var(--text-main); font-weight: 800;">@((viewOnly) ? "مشاهده نامه" : "ثبت نامه جدید")</h2>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">شماره نامه</label>
                    <input type="text" @bind="editingLetter.LetterNumber" class="input-field" style="font-family: var(--font-en);" readonly="@viewOnly" />
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">گیرنده</label>
                    <input type="text" @bind="editingLetter.Recipient" class="input-field" readonly="@viewOnly" />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">موضوع نامه</label>
                <input type="text" @bind="editingLetter.Subject" class="input-field" readonly="@viewOnly" />
            </div>

            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">متن نامه</label>
                <textarea @bind="editingLetter.Content" class="input-field" style="min-height: 250px; resize: vertical;" readonly="@viewOnly"></textarea>
            </div>

            <div style="display: flex; gap: 1rem;">
                @if (!viewOnly)
                {
                    <button class="btn-primary" style="flex: 1;" @onclick="SaveLetter">ذخیره در دبیرخانه</button>
                }
                <button style="flex: 1; background: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-main); border-radius: var(--radius-md); cursor: pointer; font-weight: bold;" @onclick="CloseModal">بستن</button>
            </div>
        </div>
    </div>
}

@code {
    private List<OfficialLetter> letters = new();
    private bool isLoading = true;
    private bool isModalOpen = false;
    private bool viewOnly = false;
    private OfficialLetter editingLetter = new();

    protected override async Task OnInitializedAsync()
    {
        // 🚀 سرعت بالا: بدون چک کردن دیتابیس
        await Task.Yield();
        await LoadLetters();
    }

    private async Task LoadLetters()
    {
        isLoading = true;
        try { letters = await DbContext.OfficialLetters.AsNoTracking().OrderByDescending(l => l.Id).ToListAsync(); }
        finally { isLoading = false; }
    }

    private void OpenAddModal() { editingLetter = new OfficialLetter { LetterNumber = "LTR-" + DateTime.Now.ToString("MMdd-HHmm") }; viewOnly = false; isModalOpen = true; }
    private void ViewLetter(OfficialLetter l) { editingLetter = l; viewOnly = true; isModalOpen = true; }
    private void CloseModal() { isModalOpen = false; }

    private async Task SaveLetter()
    {
        if (string.IsNullOrWhiteSpace(editingLetter.Subject)) return;
        try { DbContext.OfficialLetters.Add(editingLetter); await DbContext.SaveChangesAsync(); await LoadLetters(); CloseModal(); }
        catch (Exception) { }
    }

    private async Task DeleteLetter(OfficialLetter l)
    {
        try { DbContext.OfficialLetters.Remove(l); await DbContext.SaveChangesAsync(); await LoadLetters(); } catch (Exception) { }
    }
}
@page "/crm"
@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="module-header">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2rem;">
        <div>
            <h1 style="color:var(--primary-color);font-weight:800;font-size:1.8rem;margin-bottom:0.4rem;">مدیریت مشتریان (CRM)</h1>
            <p style="color:var(--text-muted);margin:0;font-size:0.9rem;">پروفایل مشتریان، تاریخچه خرید، یادآور و لاگ فعالیت</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
            <button style="padding:0.6rem 1.2rem;border-radius:var(--radius-md);cursor:pointer;font-family:var(--font-fa);font-size:0.88rem;font-weight:700;background:var(--bg-color);color:var(--primary-color);border:1px solid var(--primary-color);" @onclick="OpenReminderModal">+ یادآور جدید</button>
            <button class="btn-primary" @onclick="OpenAddModal">+ مشتری جدید</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(pageError))
    {
        <div style="padding:0.75rem 1rem;background:rgba(239,68,68,0.1);border:1px solid var(--danger);border-radius:var(--radius-md);color:var(--danger);font-size:0.88rem;margin-bottom:1rem;">@pageError</div>
    }

    <!-- یادآورهای فوری -->
    @if (urgentReminders.Any())
    {
        <div style="background:rgba(239,68,68,0.07);border:1px solid rgba(239,68,68,0.3);border-radius:var(--radius-md);padding:0.75rem 1.25rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
            <span style="color:var(--danger);font-weight:bold;font-size:0.88rem;">⚠ یادآورهای امروز و گذشته:</span>
            @foreach (var r in urgentReminders.Take(3))
            {
                <span style="font-size:0.82rem;padding:0.2rem 0.6rem;background:rgba(239,68,68,0.12);border-radius:3px;color:var(--danger);">@r.Title @(string.IsNullOrEmpty(r.CustomerName) ? "" : $"— {r.CustomerName}")</span>
            }
            <button style="background:none;border:none;color:var(--danger);cursor:pointer;font-family:var(--font-fa);font-size:0.8rem;text-decoration:underline;" @onclick="DismissAllUrgent">رد کردن همه</button>
        </div>
    }

    <!-- فیلتر -->
    <div class="card" style="margin-bottom:1.5rem;padding:1rem 1.5rem;">
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr auto;gap:0.75rem;align-items:flex-end;">
            <div>
                <label style="font-size:0.8rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">جستجو (نام، شرکت، تلفن، کد ملی)</label>
                <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="جستجو..." class="input-field" style="margin-bottom:0;" />
            </div>
            <div>
                <label style="font-size:0.8rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">نوع مشتری</label>
                <select @bind="filterType" class="input-field" style="margin-bottom:0;">
                    <option value="">همه</option>
                    <option>خریدار عادی</option><option>همکار</option><option>پیمانکار</option>
                    <option>دولتی</option><option>عمده‌فروش</option>
                </select>
            </div>
            <div>
                <label style="font-size:0.8rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">منبع جذب</label>
                <select @bind="filterSource" class="input-field" style="margin-bottom:0;">
                    <option value="">همه منابع</option>
                    <option>اینستاگرام</option><option>معرفی</option><option>وب‌سایت</option>
                    <option>تبلیغات</option><option>نمایشگاه</option><option>سایر</option>
                </select>
            </div>
            <div>
                <label style="font-size:0.8rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">وضعیت</label>
                <select @bind="filterActive" class="input-field" style="margin-bottom:0;">
                    <option value="">همه</option>
                    <option value="true">فعال</option>
                    <option value="false">غیرفعال</option>
                </select>
            </div>
            <button style="padding:0.75rem 1rem;border-radius:var(--radius-md);cursor:pointer;font-family:var(--font-fa);font-size:0.85rem;background:var(--bg-color);color:var(--text-muted);border:1px solid var(--border-color);" @onclick="ClearFilters">پاک</button>
        </div>
        <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--text-muted);">
            <span class="industrial-num" style="color:var(--primary-color);">@filteredCustomers.Count</span> مشتری
        </div>
    </div>

    <!-- جدول مشتریان -->
    <div class="card" style="padding:0;overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid var(--border-color);background:var(--bg-color);">
                    <th style="padding:1rem 1.25rem;text-align:right;font-size:0.82rem;color:var(--text-muted);font-weight:600;">مشتری</th>
                    <th style="padding:1rem 1.25rem;text-align:right;font-size:0.82rem;color:var(--text-muted);font-weight:600;">نوع / منبع</th>
                    <th style="padding:1rem 1.25rem;text-align:right;font-size:0.82rem;color:var(--text-muted);font-weight:600;">آخرین خرید</th>
                    <th style="padding:1rem 1.25rem;text-align:right;font-size:0.82rem;color:var(--text-muted);font-weight:600;">جمع خرید (ریال)</th>
                    <th style="padding:1rem 1.25rem;text-align:center;font-size:0.82rem;color:var(--text-muted);font-weight:600;">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="5" style="padding:3rem;text-align:center;"><div class="loader-pulse-ring" style="margin:0 auto;"></div></td></tr>
                }
                else if (!filteredCustomers.Any())
                {
                    <tr><td colspan="5" style="padding:4rem;text-align:center;color:var(--text-muted);">مشتری‌ای یافت نشد.</td></tr>
                }
                else
                {
                    @foreach (var c in filteredCustomers)
                    {
                        <tr style="border-bottom:1px solid var(--border-color);">
                            <td style="padding:1rem 1.25rem;">
                                <div style="font-weight:700;color:var(--text-main);">@c.FullName</div>
                                @if (!string.IsNullOrEmpty(c.CompanyName)) { <div style="font-size:0.78rem;color:var(--accent-color);">@c.CompanyName</div> }
                                @if (!string.IsNullOrEmpty(c.PhoneNumber)) { <div class="industrial-num" style="font-size:0.75rem;color:var(--text-muted);">@c.PhoneNumber</div> }
                                @if (!string.IsNullOrEmpty(c.City)) { <div style="font-size:0.72rem;color:var(--text-muted);">@c.City@(!string.IsNullOrEmpty(c.Province) ? $"، {c.Province}" : "")</div> }
                            </td>
                            <td style="padding:1rem 1.25rem;">
                                <span style="font-size:0.78rem;padding:0.2rem 0.5rem;border-radius:3px;background:rgba(245,158,11,0.1);color:var(--primary-color);">@c.CustomerType</span>
                                @if (!string.IsNullOrEmpty(c.LeadSource))
                                {
                                    <div style="margin-top:0.3rem;font-size:0.75rem;padding:0.15rem 0.4rem;border-radius:3px;background:rgba(59,130,246,0.1);color:var(--accent-color);display:inline-block;">@c.LeadSource</div>
                                }
                                @if (!string.IsNullOrEmpty(c.ReferredBy))
                                {
                                    <div style="font-size:0.72rem;color:var(--text-muted);margin-top:0.15rem;">معرف: @c.ReferredBy</div>
                                }
                            </td>
                            <td style="padding:1rem 1.25rem;">
                                @if (c.LastPurchaseDate.HasValue)
                                {
                                    <div class="industrial-num" style="font-size:0.85rem;">@c.LastPurchaseDate.Value.ToString("yyyy/MM/dd")</div>
                                }
                                else { <div style="color:var(--text-muted);font-size:0.82rem;">هنوز خریدی نداشته</div> }
                                <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.1rem;"><span class="industrial-num">@c.TotalInvoiceCount</span> فاکتور</div>
                            </td>
                            <td style="padding:1rem 1.25rem;">
                                <div class="industrial-num" style="color:var(--success);font-weight:bold;">@c.TotalPurchaseAmount.ToString("N0")</div>
                            </td>
                            <td style="padding:1rem 1.25rem;text-align:center;">
                                <div style="display:flex;gap:0.4rem;justify-content:center;flex-wrap:wrap;">
                                    <button style="background:var(--bg-color);border:1px solid var(--border-color);color:var(--text-main);cursor:pointer;padding:0.3rem 0.5rem;border-radius:var(--radius-md);font-size:0.78rem;" @onclick="() => OpenEditModal(c)">ویرایش</button>
                                    <button style="background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.3);color:var(--accent-color);cursor:pointer;padding:0.3rem 0.5rem;border-radius:var(--radius-md);font-size:0.78rem;" @onclick="() => OpenActivityModal(c)">فعالیت‌ها</button>
                                    <button style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);color:var(--primary-color);cursor:pointer;padding:0.3rem 0.5rem;border-radius:var(--radius-md);font-size:0.78rem;" @onclick="() => OpenReminderForCustomer(c)">یادآور</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- مودال افزودن/ویرایش مشتری -->
@if (isEditModalOpen)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(9,9,11,0.93);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseEditModal">
        <div class="card" style="width:100%;max-width:680px;max-height:94vh;overflow-y:auto;border-top:3px solid var(--primary-color);" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;border-bottom:1px solid var(--border-color);padding-bottom:1rem;">
                <h2 style="font-size:1.2rem;color:var(--text-main);font-weight:800;">@(editingId==0 ? "افزودن مشتری جدید" : "ویرایش مشتری")</h2>
                <button style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.5rem;" @onclick="CloseEditModal">✕</button>
            </div>
            @if (!string.IsNullOrEmpty(modalError)) { <div style="padding:0.75rem 1rem;background:rgba(239,68,68,0.1);border:1px solid var(--danger);border-radius:var(--radius-md);color:var(--danger);font-size:0.88rem;margin-bottom:1rem;">@modalError</div> }

            <div style="background:var(--bg-color);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1rem;">
                <p style="font-size:0.8rem;color:var(--text-muted);font-weight:bold;margin-bottom:1rem;">اطلاعات اصلی</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">نام و نام خانوادگی *</label><input type="text" @bind="cForm.FullName" class="input-field" style="margin-bottom:0;" /></div>
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">نام شرکت / پروژه</label><input type="text" @bind="cForm.CompanyName" class="input-field" style="margin-bottom:0;" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">موبایل</label><input type="text" @bind="cForm.PhoneNumber" class="input-field" style="margin-bottom:0;direction:ltr;font-family:var(--font-en);" placeholder="09xxxxxxxxx" /></div>
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">کد ملی / شناسه</label><input type="text" @bind="cForm.NationalId" class="input-field" style="margin-bottom:0;direction:ltr;font-family:var(--font-en);" /></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">شهر</label><input type="text" @bind="cForm.City" class="input-field" style="margin-bottom:0;" /></div>
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">استان</label><input type="text" @bind="cForm.Province" class="input-field" style="margin-bottom:0;" /></div>
                </div>
                <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">آدرس</label><input type="text" @bind="cForm.Address" class="input-field" style="margin-bottom:0;" /></div>
            </div>

            <div style="background:var(--bg-color);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1rem;">
                <p style="font-size:0.8rem;color:var(--text-muted);font-weight:bold;margin-bottom:1rem;">اطلاعات بازاریابی</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div>
                        <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">نوع مشتری</label>
                        <select @bind="cForm.CustomerType" class="input-field" style="margin-bottom:0;">
                            <option>خریدار عادی</option><option>همکار</option><option>پیمانکار</option><option>دولتی</option><option>عمده‌فروش</option>
                        </select>
                    </div>
                    <div>
                        <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">منبع آشنایی / جذب</label>
                        <select @bind="cForm.LeadSource" class="input-field" style="margin-bottom:0;">
                            <option value="">انتخاب کنید...</option>
                            <option>اینستاگرام</option><option>معرفی</option><option>وب‌سایت</option>
                            <option>تبلیغات</option><option>نمایشگاه</option><option>سایر</option>
                        </select>
                    </div>
                </div>
                @if (cForm.LeadSource == "معرفی")
                {
                    <div><label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">نام معرف</label><input type="text" @bind="cForm.ReferredBy" class="input-field" style="margin-bottom:0;" /></div>
                }
            </div>

            <div style="background:var(--bg-color);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1.5rem;">
                <p style="font-size:0.8rem;color:var(--text-muted);font-weight:bold;margin-bottom:0.75rem;">یادداشت</p>
                <textarea @bind="cForm.Notes" class="input-field" style="min-height:70px;resize:vertical;margin-bottom:0;" placeholder="توضیحات اضافی درباره این مشتری..."></textarea>
            </div>

            <div style="display:flex;gap:1rem;border-top:1px solid var(--border-color);padding-top:1.25rem;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveCustomer" disabled="@isSaving">
                    @if (isSaving) { <span>در حال ذخیره...</span> } else { <span>ذخیره مشتری</span> }
                </button>
                <button style="flex:1;padding:0.6rem;border-radius:var(--radius-md);cursor:pointer;font-family:var(--font-fa);font-weight:bold;background:transparent;border:1px solid var(--border-color);color:var(--text-main);" @onclick="CloseEditModal">انصراف</button>
            </div>
        </div>
    </div>
}

<!-- مودال لاگ فعالیت‌ها -->
@if (isActivityModalOpen && activeCustomer != null)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(9,9,11,0.93);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseActivityModal">
        <div class="card" style="width:100%;max-width:680px;max-height:94vh;overflow-y:auto;border-top:3px solid var(--accent-color);" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;border-bottom:1px solid var(--border-color);padding-bottom:1rem;">
                <div>
                    <h2 style="font-size:1.1rem;color:var(--text-main);font-weight:800;">فعالیت‌ها و تماس‌ها</h2>
                    <p style="font-size:0.82rem;color:var(--accent-color);margin:0;">@activeCustomer.FullName</p>
                </div>
                <button style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.5rem;" @onclick="CloseActivityModal">✕</button>
            </div>

            <!-- فرم ثبت فعالیت جدید -->
            <div style="background:var(--bg-color);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;margin-bottom:1.5rem;">
                <p style="font-size:0.82rem;color:var(--text-muted);font-weight:bold;margin-bottom:1rem;">ثبت فعالیت / تماس جدید</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div>
                        <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.8rem;">نوع فعالیت</label>
                        <select @bind="actForm.ActivityType" class="input-field" style="margin-bottom:0;">
                            <option>تماس</option><option>جلسه</option><option>پیامک</option><option>ایمیل</option><option>بازدید</option><option>سایر</option>
                        </select>
                    </div>
                    <div>
                        <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.8rem;">تاریخ</label>
                        <input type="datetime-local" @bind="actForm.ActivityDate" class="input-field" style="margin-bottom:0;font-family:var(--font-en);" />
                    </div>
                </div>
                <div style="margin-bottom:1rem;">
                    <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.8rem;">موضوع</label>
                    <input type="text" @bind="actForm.Subject" class="input-field" style="margin-bottom:0;" placeholder="خلاصه تماس / جلسه" />
                </div>
                <div style="margin-bottom:1rem;">
                    <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.8rem;">توضیحات</label>
                    <textarea @bind="actForm.Description" class="input-field" style="min-height:60px;resize:vertical;margin-bottom:0;" placeholder="جزئیات..."></textarea>
                </div>
                <div style="margin-bottom:1rem;">
                    <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.8rem;">نتیجه / برآیند</label>
                    <input type="text" @bind="actForm.Outcome" class="input-field" style="margin-bottom:0;" placeholder="نتیجه تماس" />
                </div>
                <button class="btn-primary" @onclick="SaveActivity" disabled="@isSaving" style="width:100%;">
                    @if (isSaving) { <span>در حال ذخیره...</span> } else { <span>ثبت فعالیت</span> }
                </button>
            </div>

            <!-- تایم‌لاین فعالیت‌ها -->
            @if (!customerActivities.Any())
            {
                <div style="text-align:center;color:var(--text-muted);padding:2rem;font-size:0.85rem;">هنوز فعالیتی ثبت نشده است.</div>
            }
            else
            {
                <div style="position:relative;padding-right:1.5rem;">
                    <div style="position:absolute;right:0.6rem;top:0;bottom:0;width:2px;background:var(--border-color);"></div>
                    @foreach (var act in customerActivities.OrderByDescending(a => a.ActivityDate))
                    {
                        var actColor = act.ActivityType switch { "تماس" => "var(--success)", "جلسه" => "var(--primary-color)", "بازدید" => "var(--accent-color)", _ => "var(--text-muted)" };
                        <div style="position:relative;margin-bottom:1.25rem;">
                            <div style="position:absolute;right:-1.95rem;top:0.3rem;width:12px;height:12px;border-radius:50%;background:@actColor;border:2px solid var(--bg-color);"></div>
                            <div style="background:var(--bg-color);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1rem;">
                                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
                                    <div>
                                        <span style="font-size:0.78rem;padding:0.15rem 0.4rem;border-radius:3px;background:rgba(16,185,129,0.1);color:@actColor;">@act.ActivityType</span>
                                        @if (!string.IsNullOrEmpty(act.Subject)) { <span style="font-size:0.85rem;font-weight:600;color:var(--text-main);margin-right:0.5rem;">@act.Subject</span> }
                                    </div>
                                    <span class="industrial-num" style="font-size:0.75rem;color:var(--text-muted);">@act.ActivityDate.ToString("yyyy/MM/dd HH:mm")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(act.Description)) { <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:0.3rem;">@act.Description</p> }
                                @if (!string.IsNullOrEmpty(act.Outcome)) { <div style="font-size:0.8rem;color:var(--success);">نتیجه: @act.Outcome</div> }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- مودال یادآور -->
@if (isReminderModalOpen)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(9,9,11,0.93);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseReminderModal">
        <div class="card" style="width:100%;max-width:500px;border-top:3px solid var(--primary-color);" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;border-bottom:1px solid var(--border-color);padding-bottom:1rem;">
                <h2 style="font-size:1.1rem;color:var(--text-main);font-weight:800;">ثبت یادآور جدید</h2>
                <button style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.5rem;" @onclick="CloseReminderModal">✕</button>
            </div>
            <div style="margin-bottom:1rem;">
                <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">عنوان یادآور *</label>
                <input type="text" @bind="remForm.Title" class="input-field" style="margin-bottom:0;" placeholder="مثال: پیگیری سفارش، تماس با مشتری" />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                <div>
                    <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">تاریخ یادآور *</label>
                    <input type="date" @bind="remForm.ReminderDate" class="input-field" style="margin-bottom:0;font-family:var(--font-en);" />
                </div>
                <div>
                    <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">اولویت</label>
                    <select @bind="remForm.Priority" class="input-field" style="margin-bottom:0;">
                        <option>کم</option><option>متوسط</option><option>مهم</option><option>فوری</option>
                    </select>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(remForm.CustomerName))
            {
                <div style="padding:0.5rem 0.75rem;background:rgba(59,130,246,0.08);border-radius:var(--radius-md);margin-bottom:1rem;font-size:0.82rem;color:var(--accent-color);">
                    مرتبط با مشتری: <strong>@remForm.CustomerName</strong>
                </div>
            }
            <div style="margin-bottom:1.5rem;">
                <label style="display:block;margin-bottom:0.3rem;color:var(--text-muted);font-size:0.82rem;">توضیحات</label>
                <textarea @bind="remForm.Description" class="input-field" style="min-height:70px;resize:vertical;margin-bottom:0;" placeholder="جزئیات یادآور..."></textarea>
            </div>
            <div style="display:flex;gap:1rem;border-top:1px solid var(--border-color);padding-top:1.25rem;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveReminder" disabled="@isSaving">
                    @if (isSaving) { <span>در حال ذخیره...</span> } else { <span>ثبت یادآور</span> }
                </button>
                <button style="flex:1;padding:0.6rem;border-radius:var(--radius-md);cursor:pointer;font-family:var(--font-fa);font-weight:bold;background:transparent;border:1px solid var(--border-color);color:var(--text-main);" @onclick="CloseReminderModal">انصراف</button>
            </div>
        </div>
    </div>
}

@code {
    private AppDbContext _db = null!;
    private List<Customer> allCustomers = new();
    private List<Customer> filteredCustomers = new();
    private List<CustomerReminder> urgentReminders = new();
    private List<CustomerActivity> customerActivities = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isEditModalOpen = false;
    private bool isActivityModalOpen = false;
    private bool isReminderModalOpen = false;
    private int editingId = 0;
    private string pageError = "";
    private string modalError = "";
    private Customer? activeCustomer;

    private string _searchQuery = "";
    private string searchQuery { get => _searchQuery; set { _searchQuery = value; ApplyFilter(); } }
    private string _filterType = "";
    private string filterType { get => _filterType; set { _filterType = value; ApplyFilter(); } }
    private string _filterSource = "";
    private string filterSource { get => _filterSource; set { _filterSource = value; ApplyFilter(); } }
    private string _filterActive = "";
    private string filterActive { get => _filterActive; set { _filterActive = value; ApplyFilter(); } }

    private Customer cForm = new();
    private CustomerActivity actForm = new();
    private CustomerReminder remForm = new();

    protected override async Task OnInitializedAsync()
    {
        _db = await DbFactory.CreateDbContextAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allCustomers = await _db.Customers.AsNoTracking()
                .OrderByDescending(c => c.LastPurchaseDate ?? c.RegisterDate)
                .ToListAsync();

            urgentReminders = await _db.CustomerReminders.AsNoTracking()
                .Where(r => !r.IsDismissed && r.ReminderDate <= DateTime.Now.AddDays(1))
                .OrderBy(r => r.ReminderDate)
                .ToListAsync();

            ApplyFilter();
        }
        catch (Exception ex) { pageError = $"خطا: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private void ApplyFilter()
    {
        var q = allCustomers.AsEnumerable();
        if (!string.IsNullOrEmpty(_filterType)) q = q.Where(c => c.CustomerType == _filterType);
        if (!string.IsNullOrEmpty(_filterSource)) q = q.Where(c => c.LeadSource == _filterSource);
        if (_filterActive == "true") q = q.Where(c => c.IsActive);
        else if (_filterActive == "false") q = q.Where(c => !c.IsActive);
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var s = _searchQuery.ToLower();
            q = q.Where(c =>
                c.FullName.ToLower().Contains(s) ||
                (c.CompanyName ?? "").ToLower().Contains(s) ||
                (c.PhoneNumber ?? "").Contains(s) ||
                (c.NationalId ?? "").Contains(s));
        }
        filteredCustomers = q.ToList();
    }

    private void ClearFilters()
    {
        _searchQuery = ""; _filterType = ""; _filterSource = ""; _filterActive = "";
        ApplyFilter(); StateHasChanged();
    }

    private void OpenAddModal()
    {
        editingId = 0;
        cForm = new Customer { CustomerType = "خریدار عادی", IsActive = true, RegisterDate = DateTime.Now };
        modalError = ""; isEditModalOpen = true;
    }

    private void OpenEditModal(Customer c)
    {
        editingId = c.Id;
        cForm = new Customer
        {
            FullName = c.FullName, CompanyName = c.CompanyName, PhoneNumber = c.PhoneNumber,
            Address = c.Address, City = c.City, Province = c.Province,
            Email = c.Email, NationalId = c.NationalId, Notes = c.Notes,
            IsActive = c.IsActive, CustomerType = c.CustomerType,
            LeadSource = c.LeadSource, ReferredBy = c.ReferredBy,
            RegisterDate = c.RegisterDate
        };
        modalError = ""; isEditModalOpen = true;
    }

    private async Task CloseEditModal() { isEditModalOpen = false; await InvokeAsync(StateHasChanged); }

    private async Task SaveCustomer()
    {
        if (string.IsNullOrWhiteSpace(cForm.FullName)) { modalError = "نام الزامی است."; return; }
        isSaving = true; modalError = "";
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (editingId == 0)
            {
                db.Customers.Add(cForm);
            }
            else
            {
                var existing = await db.Customers.FindAsync(editingId);
                if (existing != null)
                {
                    existing.FullName = cForm.FullName; existing.CompanyName = cForm.CompanyName;
                    existing.PhoneNumber = cForm.PhoneNumber; existing.Address = cForm.Address;
                    existing.City = cForm.City; existing.Province = cForm.Province;
                    existing.Email = cForm.Email; existing.NationalId = cForm.NationalId;
                    existing.Notes = cForm.Notes; existing.IsActive = cForm.IsActive;
                    existing.CustomerType = cForm.CustomerType;
                    existing.LeadSource = cForm.LeadSource; existing.ReferredBy = cForm.ReferredBy;
                }
            }
            await db.SaveChangesAsync();
            await LoadData();
            isEditModalOpen = false;
        }
        catch (Exception ex) { modalError = $"خطا: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private async Task OpenActivityModal(Customer c)
    {
        activeCustomer = c;
        actForm = new CustomerActivity { CustomerId = c.Id, ActivityDate = DateTime.Now, ActivityType = "تماس", OperatorName = "مدیر سیستم" };
        try
        {
            customerActivities = await _db.CustomerActivities.AsNoTracking()
                .Where(a => a.CustomerId == c.Id)
                .OrderByDescending(a => a.ActivityDate)
                .ToListAsync();
        }
        catch { customerActivities = new(); }
        isActivityModalOpen = true;
    }

    private async Task CloseActivityModal() { isActivityModalOpen = false; activeCustomer = null; await InvokeAsync(StateHasChanged); }

    private async Task SaveActivity()
    {
        if (string.IsNullOrWhiteSpace(actForm.Subject)) { return; }
        isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            actForm.CustomerId = activeCustomer!.Id;
            db.CustomerActivities.Add(actForm);
            await db.SaveChangesAsync();
            customerActivities = await _db.CustomerActivities.AsNoTracking()
                .Where(a => a.CustomerId == activeCustomer.Id)
                .OrderByDescending(a => a.ActivityDate)
                .ToListAsync();
            actForm = new CustomerActivity { CustomerId = activeCustomer.Id, ActivityDate = DateTime.Now, ActivityType = "تماس", OperatorName = "مدیر سیستم" };
        }
        catch { }
        finally { isSaving = false; }
    }

    private void OpenReminderModal()
    {
        remForm = new CustomerReminder { ReminderDate = DateTime.Now.AddDays(1), Priority = "متوسط" };
        isReminderModalOpen = true;
    }

    private void OpenReminderForCustomer(Customer c)
    {
        remForm = new CustomerReminder { CustomerId = c.Id, CustomerName = c.FullName, ReminderDate = DateTime.Now.AddDays(1), Priority = "متوسط" };
        isReminderModalOpen = true;
    }

    private async Task CloseReminderModal() { isReminderModalOpen = false; await InvokeAsync(StateHasChanged); }

    private async Task SaveReminder()
    {
        if (string.IsNullOrWhiteSpace(remForm.Title)) { return; }
        isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            remForm.CreatedAt = DateTime.Now;
            db.CustomerReminders.Add(remForm);
            await db.SaveChangesAsync();
            await LoadData();
            isReminderModalOpen = false;
        }
        catch { }
        finally { isSaving = false; }
    }

    private async Task DismissAllUrgent()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var ids = urgentReminders.Select(r => r.Id).ToList();
            var toUpdate = await db.CustomerReminders.Where(r => ids.Contains(r.Id)).ToListAsync();
            foreach (var r in toUpdate) r.IsDismissed = true;
            await db.SaveChangesAsync();
            urgentReminders.Clear();
        }
        catch { }
    }

    public void Dispose() => _db?.Dispose();
}

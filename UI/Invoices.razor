    {
        1 => "#94a3b8", 2 => "#8b5cf6", 3 => "#3b82f6",
        4 => "#f59e0b", 5 => "#f97316", 6 => "#10b981", _ => "#94a3b8"
    };

    // ── چهارچوب فلزی ──
    private void AddFrameItem()
    {
        if (string.IsNullOrWhiteSpace(frameItemForm.Name)) return;
        frameItems.Add(new FrameOrderItem
        {
            Name = frameItemForm.Name, FrameType = frameItemForm.FrameType,
            OpeningDirection = frameItemForm.OpeningDirection,
            UnitPrice = frameItemForm.UnitPrice, Quantity = frameItemForm.Quantity,
            TaxRate = taxRate
        });
        frameItemForm = new FrameOrderItem { FrameType = "چهارچوب فرانسوی", OpeningDirection = "راست‌باز", Quantity = 1 };
        StateHasChanged();
    }

    // ── پلاک ساختارمند ──
    private void OnPlatePart1Input(ChangeEventArgs e) { editingInvoice.VehiclePlatePart1 = e.Value?.ToString() ?? string.Empty; SyncPlate(); }
    private void OnPlateLetterChange(ChangeEventArgs e) { editingInvoice.VehiclePlateLetter = e.Value?.ToString() ?? string.Empty; SyncPlate(); }
    private void OnPlatePart2Input(ChangeEventArgs e) { editingInvoice.VehiclePlatePart2 = e.Value?.ToString() ?? string.Empty; SyncPlate(); }
    private void OnPlateRegionInput(ChangeEventArgs e) { editingInvoice.VehiclePlateRegion = e.Value?.ToString() ?? string.Empty; SyncPlate(); }

    private void SyncPlate()
    {
        var p1 = editingInvoice.VehiclePlatePart1;
        var lt = editingInvoice.VehiclePlateLetter;
        var p2 = editingInvoice.VehiclePlatePart2;
        var rg = editingInvoice.VehiclePlateRegion;
        if (!string.IsNullOrEmpty(p1) && !string.IsNullOrEmpty(lt))
            editingInvoice.VehiclePlate = $"{p1}{lt}{p2}-{rg}";
    }

    // ── مدیریت نرخ مالیات ──
    private string GetActiveTaxDisplay()
    {
        var r = editingInvoice.CustomTaxRate >= 0 ? editingInvoice.CustomTaxRate : taxRate;
        return r switch { 0m => "0", 0.05m => "5", 0.09m => "9", _ => "custom" };
    }

    private void OnTaxRateChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        decimal r = val switch { "0" => 0m, "5" => 0.05m, "9" => 0.09m, _ => taxRate };
        editingInvoice.CustomTaxRate = r;
        taxRate = r;
        CalculateTotals();
    }

    public void Dispose() => _db?.Dispose();
}

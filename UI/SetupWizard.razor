@page "/setup"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavManager

<style>
    .setup-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-color);
        padding: 2rem;
    }
    .setup-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-top: 3px solid var(--primary-color);
        border-radius: var(--radius-lg);
        padding: 3rem;
        width: 100%;
        max-width: 600px;
    }
    .setup-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }
    .setup-header h1 {
        color: var(--primary-color);
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        font-family: var(--font-en);
        letter-spacing: 2px;
    }
    .setup-header p {
        color: var(--text-muted);
        font-size: 0.95rem;
    }
</style>

<div class="setup-wrapper">
    <div class="setup-card">
        <div class="setup-header">
            <h1>SMART<span style="color: var(--text-main);">ERP</span></h1>
            <p>اطلاعات اولیه مجموعه را برای شخصی‌سازی سیستم وارد کنید.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        @if (isLoading)
        {
            <div style="text-align:center; padding: 2rem;">
                <div class="loader-pulse-ring" style="margin: 0 auto;"></div>
                <p style="margin-top:1rem; color: var(--text-muted);">در حال ذخیره‌سازی...</p>
            </div>
        }
        else
        {
            <div style="margin-bottom: 1rem;">
                <label style="display: block; margin-bottom: 0.4rem; color: var(--text-muted); font-size: 0.85rem;">نام شرکت / مجموعه *</label>
                <input type="text" class="input-field" @bind="setting.CompanyName" placeholder="مثال: گروه صنعتی مشعوف" />
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="display: block; margin-bottom: 0.4rem; color: var(--text-muted); font-size: 0.85rem;">نام مدیریت</label>
                <input type="text" class="input-field" @bind="setting.ManagerName" />
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="display: block; margin-bottom: 0.4rem; color: var(--text-muted); font-size: 0.85rem;">شماره تماس</label>
                <input type="text" class="input-field" @bind="setting.PhoneNumber" style="font-family: var(--font-en); direction: ltr;" />
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.4rem; color: var(--text-muted); font-size: 0.85rem;">آدرس</label>
                <textarea class="input-field" @bind="setting.Address" rows="2" style="height: auto; resize: none; margin-bottom: 0;" placeholder="آدرس کامل جهت درج در فاکتور"></textarea>
            </div>

            <div style="margin-bottom: 2rem;">
                <label style="display: block; margin-bottom: 0.4rem; color: var(--text-muted); font-size: 0.85rem;">لوگوی مجموعه (PNG یا JPG — حداکثر ۲ مگابایت)</label>
                <div onclick="document.getElementById('logoInputSetup').click()"
                     style="border: 2px dashed var(--border-color); border-radius: var(--radius-md); padding: 1.5rem; text-align: center; cursor: pointer; background: var(--bg-color);">
                    @if (string.IsNullOrEmpty(setting.LogoPath) || setting.LogoPath == "/images/default-logo.png")
                    {
                        <div style="font-size: 2rem; color: var(--text-muted); margin-bottom: 0.5rem;">📷</div>
                        <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">برای انتخاب لوگو کلیک کنید</p>
                    }
                    else
                    {
                        <img src="@setting.LogoPath" style="max-width: 150px; max-height: 100px; object-fit: contain;" alt="Logo" />
                        <p style="color: var(--primary-color); font-size: 0.8rem; margin: 0.5rem 0 0;">برای تغییر کلیک کنید</p>
                    }
                    <InputFile id="logoInputSetup" style="display: none;" OnChange="HandleLogoUpload" accept="image/png,image/jpeg" />
                </div>
            </div>

            <button class="btn-primary" style="width: 100%; padding: 0.85rem;" @onclick="SaveConfiguration">
                ثبت و ورود به سیستم
            </button>
        }
    </div>
</div>

@code {
    private CompanySetting setting = new() { Id = 1 };
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.CompanySettings.AsNoTracking().FirstOrDefaultAsync();
        if (existing != null)
            setting = existing;
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        errorMessage = string.Empty;
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024) { errorMessage = "حجم لوگو نباید بیشتر از ۲ مگابایت باشد."; return; }
        try
        {
            var buffer = new byte[file.Size];
            using var stream = file.OpenReadStream(2 * 1024 * 1024);
            await stream.ReadAsync(buffer);
            setting.LogoPath = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
        catch { errorMessage = "خطا در پردازش تصویر."; }
    }

    private async Task SaveConfiguration()
    {
        if (string.IsNullOrWhiteSpace(setting.CompanyName)) { errorMessage = "لطفاً نام مجموعه را وارد کنید."; return; }
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            await using var saveDb = await DbFactory.CreateDbContextAsync();
            var existing = await saveDb.CompanySettings.FirstOrDefaultAsync();
            if (existing == null)
            {
                setting.Id = 1;
                saveDb.CompanySettings.Add(setting);
            }
            else
            {
                existing.CompanyName = setting.CompanyName;
                existing.ManagerName = setting.ManagerName;
                existing.Address = setting.Address;
                existing.PhoneNumber = setting.PhoneNumber;
                existing.LogoPath = setting.LogoPath;
            }
            await saveDb.SaveChangesAsync();
            NavManager.NavigateTo("/");
        }
        catch (Exception) { errorMessage = "خطا در ذخیره‌سازی اطلاعات."; }
        finally { isLoading = false; }
    }
}

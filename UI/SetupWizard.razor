@page "/setup"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject AppDbContext DbContext
@inject NavigationManager NavManager

<style>
    .setup-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
        padding: 2rem;
    }

    .setup-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        padding: 3rem;
        width: 100%;
        max-width: 600px;
        border: 1px solid rgba(255,255,255,0.5);
    }

    .setup-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .setup-header h1 {
        color: #102a43;
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .setup-header p {
        color: #627d98;
        font-size: 0.95rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #334e68;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 2px solid #e4e7eb;
        border-radius: 12px;
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

    .form-control:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
        background: #ffffff;
    }

    .logo-upload-box {
        border: 2px dashed #cbd5e1;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        background: #f8fafc;
    }

    .logo-upload-box:hover {
        border-color: #2563eb;
        background: #f1f5f9;
    }

    .logo-preview {
        max-width: 150px;
        max-height: 150px;
        border-radius: 12px;
        margin-top: 1rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .btn-submit {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        margin-top: 1rem;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37,99,235,0.2);
    }

    .error-msg {
        background: #fee2e2;
        color: #ef4444;
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>

<div class="setup-wrapper">
    <div class="setup-card">
        <div class="setup-header">
            <h1>تنظیمات اولیه سیستم</h1>
            <p>لطفاً اطلاعات مجموعه خود را برای شخصی‌سازی نرم‌افزار وارد کنید.</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-msg">
                <span>⚠️</span> @ErrorMessage
            </div>
        }

        @if (isLoading)
        {
            <div style="text-align:center; padding: 2rem;">
                <div class="loader-pulse-ring" style="position:relative; margin: 0 auto;"></div>
                <p style="margin-top:1rem; color:#6b7280;">در حال ذخیره‌سازی و پیکربندی...</p>
            </div>
        }
        else
        {
            <div class="form-group">
                <label class="form-label">نام شرکت / مجموعه</label>
                <input type="text" class="form-control" @bind="setting.CompanyName" placeholder="مثال: گروه صنعتی مشعوف" />
            </div>

            <div class="form-group">
                <label class="form-label">نام مدیریت</label>
                <input type="text" class="form-control" @bind="setting.ManagerName" placeholder="مثال: حسام مشعوف" />
            </div>

            <div class="form-group">
                <label class="form-label">آدرس</label>
                <textarea class="form-control" @bind="setting.Address" rows="2" placeholder="آدرس کامل جهت درج در فاکتور"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">لوگوی مجموعه (فرمت PNG یا JPG - حداکثر ۲ مگابایت)</label>
                <div class="logo-upload-box" onclick="document.getElementById('logoInput').click()">
                    @if (string.IsNullOrEmpty(setting.LogoPath) || setting.LogoPath.EndsWith("default-logo.png"))
                    {
                        <div style="font-size: 2rem; color: #94a3b8; margin-bottom: 0.5rem;">📸</div>
                        <p style="color: #64748b; font-size: 0.9rem;">برای انتخاب لوگو کلیک کنید</p>
                    }
                    else
                    {
                        <img src="@setting.LogoPath" class="logo-preview" alt="Logo Preview" />
                        <p style="color: #2563eb; font-size: 0.8rem; margin-top: 0.5rem;">برای تغییر کلیک کنید</p>
                    }
                    <InputFile id="logoInput" style="display: none;" OnChange="HandleLogoUpload" accept="image/png, image/jpeg" />
                </div>
            </div>

            <button class="btn-submit" @onclick="SaveConfiguration">ثبت و ورود به سیستم</button>
        }
    </div>
</div>

@code {
    private CompanySetting setting = new();
    private bool isLoading = false;
    private string ErrorMessage = string.Empty;

    private const long MaxFileSize = 2 * 1024 * 1024; 

    protected override async Task OnInitializedAsync()
    {
        var existingSetting = await DbContext.CompanySettings.FirstOrDefaultAsync();
        if (existingSetting != null)
        {
            setting = existingSetting;
        }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        ErrorMessage = string.Empty;
        var file = e.File;

        if (file.Size > MaxFileSize)
        {
            ErrorMessage = "حجم لوگو نباید بیشتر از ۲ مگابایت باشد.";
            return;
        }

        if (file.ContentType != "image/png" && file.ContentType != "image/jpeg")
        {
            ErrorMessage = "لطفاً فقط فایل با فرمت PNG یا JPG انتخاب کنید.";
            return;
        }

        try
        {
            var buffer = new byte[file.Size];
            using var stream = file.OpenReadStream(MaxFileSize);
            await stream.ReadAsync(buffer);
            
            var base64 = Convert.ToBase64String(buffer);
            setting.LogoPath = $"data:{file.ContentType};base64,{base64}";
        }
        catch (Exception)
        {
            ErrorMessage = "خطا در پردازش تصویر. لطفاً تصویر دیگری امتحان کنید.";
        }
    }

    private async Task SaveConfiguration()
    {
        if (string.IsNullOrWhiteSpace(setting.CompanyName))
        {
            ErrorMessage = "لطفاً نام مجموعه را وارد کنید.";
            return;
        }

        isLoading = true;
        ErrorMessage = string.Empty;

        try
        {
            DbContext.CompanySettings.Update(setting);
            await DbContext.SaveChangesAsync();
            
            NavManager.NavigateTo("/");
        }
        catch (Exception)
        {
            ErrorMessage = "خطا در ذخیره‌سازی اطلاعات.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
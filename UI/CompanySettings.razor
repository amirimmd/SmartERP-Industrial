@page "/company-settings"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject AppDbContext DbContext

<div class="module-header">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
        <div>
            <h1 style="color: var(--primary-color); font-weight: 800; font-size: 1.8rem; margin-bottom: 0.5rem;">تنظیمات شرکت</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.95rem;">اطلاعات پایه و بانکی جهت درج در سربرگ فاکتورها</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="card" style="display: flex; justify-content: center; align-items: center; height: 40vh;">
            <div class="loader-pulse-ring" style="margin: 0 auto;"></div>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
            <div>
                <div class="card" style="margin-bottom: 2rem;">
                    <h2 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; font-weight: 800;">مشخصات و هویت حقوقی</h2>
                    
                    @if (showSuccessAlert)
                    {
                        <div style="background-color: rgba(16, 185, 129, 0.1); border: 1px solid var(--success); color: var(--success); padding: 1rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; font-weight: bold;">
                            ✅ اطلاعات مجموعه با موفقیت به‌روزرسانی شد.
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="background-color: rgba(239, 68, 68, 0.1); border: 1px solid var(--danger); color: var(--danger); padding: 1rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; font-weight: bold;">
                            ⚠️ @errorMessage
                        </div>
                    }

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">نام شرکت / مجموعه</label>
                            <input type="text" @bind="setting.CompanyName" class="input-field" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">مدیریت عامل</label>
                            <input type="text" @bind="setting.ManagerName" class="input-field" />
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">شماره تماس</label>
                            <input type="text" @bind="setting.PhoneNumber" class="input-field" style="font-family: var(--font-en); text-align: left;" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">شعار تبلیغاتی</label>
                            <input type="text" @bind="setting.Slogan" class="input-field" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">آدرس دقیق</label>
                        <textarea @bind="setting.Address" rows="2" class="input-field" style="resize: none;"></textarea>
                    </div>
                </div>

                <!-- بخش جدید اطلاعات بانکی -->
                <div class="card">
                    <h2 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; font-weight: 800;">اطلاعات حساب بانکی (جهت چاپ در فاکتور)</h2>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">نام بانک</label>
                            <input type="text" @bind="setting.BankName" class="input-field" placeholder="مثال: بانک ملت" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">نام صاحب حساب</label>
                            <input type="text" @bind="setting.CardOwner" class="input-field" placeholder="مثال: گروه صنعتی مشعوف" />
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">شماره کارت / حساب</label>
                            <input type="text" @bind="setting.AccountNumber" class="input-field" style="font-family: var(--font-en); text-align: left;" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">شماره شبا (IR)</label>
                            <input type="text" @bind="setting.ShabaNumber" class="input-field" style="font-family: var(--font-en); text-align: left;" placeholder="IR..." />
                        </div>
                    </div>
                    
                    <button class="btn-primary" @onclick="SaveChanges" style="width: 100%;">ذخیره کل تنظیمات سیستم</button>
                </div>
            </div>

            <div class="card" style="text-align: center; height: fit-content;">
                <h2 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; font-weight: 800;">لوگوی رسمی</h2>
                
                <div onclick="document.getElementById('pageLogoInput').click()" style="border: 2px dashed var(--border-color); border-radius: var(--radius-md); padding: 2rem; background-color: var(--bg-color); cursor: pointer; margin-bottom: 1.5rem;">
                    @if (string.IsNullOrEmpty(setting.LogoPath))
                    {
                        <div style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;">📸</div>
                        <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">جهت بارگذاری تصویر کلیک کنید</p>
                    }
                    else
                    {
                        <img src="@setting.LogoPath" style="max-width: 100%; max-height: 150px; border-radius: var(--radius-md); margin-bottom: 1rem;" />
                        <p style="color: var(--primary-color); font-size: 0.8rem; margin: 0; font-weight: bold;">تغییر لوگو</p>
                    }
                    <InputFile id="pageLogoInput" style="display: none;" OnChange="HandleLogoUpload" accept="image/png, image/jpeg" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    private CompanySetting setting = new();
    private bool isLoading = true;
    private bool showSuccessAlert = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.Yield();
        await LoadCompanySettings();
    }

    private async Task LoadCompanySettings()
    {
        isLoading = true;
        try
        {
            var existing = await DbContext.CompanySettings.FirstOrDefaultAsync();
            if (existing != null) { setting = existing; }
            else { setting = new CompanySetting(); }
        }
        catch (Exception ex) { errorMessage = "خطا: " + ex.Message; }
        finally { isLoading = false; }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        errorMessage = ""; showSuccessAlert = false;
        var file = e.File;
        if (file.Size > 2097152) { errorMessage = "حجم فایل زیاد است."; return; }

        try
        {
            var buffer = new byte[file.Size];
            using var stream = file.OpenReadStream(2097152);
            await stream.ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            setting.LogoPath = $"data:{file.ContentType};base64,{base64}";
        }
        catch (Exception) { errorMessage = "خطا در پردازش تصویر."; }
    }

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(setting.CompanyName)) return;
        try
        {
            DbContext.CompanySettings.Update(setting);
            await DbContext.SaveChangesAsync();
            showSuccessAlert = true;
        }
        catch (Exception ex) { errorMessage = "خطا: " + ex.Message; }
    }
}
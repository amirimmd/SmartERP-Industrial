@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="app-layout" style="display: flex; height: 100vh; width: 100vw; overflow: hidden; background-color: var(--bg-color);">
    
    <!-- Sidebar (منوی کناری نئون) -->
    <aside style="width: 260px; background-color: var(--surface-color); border-left: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 10;">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); text-align: center;">
            <h2 style="color: var(--primary-color); font-weight: 700; font-family: var(--font-en); letter-spacing: 2px; margin: 0;">
                SMART<span style="color: var(--text-main);">ERP</span>
            </h2>
            <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">Industrial Edition</span>
        </div>
        
        <nav style="flex-grow: 1; padding: 1.5rem 0; overflow-y: auto;">
            <ul style="list-style: none; padding: 0; margin: 0;">
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">داشبورد</span>
                    </NavLink>
                </li>
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/products" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">انبار و محصولات</span>
                    </NavLink>
                </li>
                
                <div style="color: var(--text-muted); font-size: 0.75rem; font-weight: bold; padding: 1rem 1.5rem 0.5rem; letter-spacing: 1px;">ارتباط با مشتری و فروش</div>

                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/personnel" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">پرسنل و نصابان</span>
                    </NavLink>
                </li>

                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/crm" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">مدیریت مشتریان (CRM)</span>
                    </NavLink>
                </li>
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/orders" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">سفارشات تولید</span>
                    </NavLink>
                </li>
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/production-reports" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">گزارشات تولید</span>
                    </NavLink>
                </li>
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/invoices" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">صدور فاکتور</span>
                    </NavLink>
                </li>
                
                <div style="color: var(--text-muted); font-size: 0.75rem; font-weight: bold; padding: 1rem 1.5rem 0.5rem; letter-spacing: 1px;">اسناد و تنظیمات</div>

                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/calendar" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">تقویم و گزارش‌ها</span>
                    </NavLink>
                </li>

                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/letters" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">نامه‌های رسمی</span>
                    </NavLink>
                </li>
                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/database-manager" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">مدیریت دیتابیس</span>
                    </NavLink>
                </li>

                <li style="margin-bottom: 0.5rem; padding: 0 1.5rem;">
                    <NavLink href="/company-settings" class="nav-item">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                        <span style="margin-right: 0.75rem; font-weight: 500;">تنظیمات شرکت</span>
                    </NavLink>
                </li>
            </ul>
        </nav>

        <div style="padding: 1.5rem; border-top: 1px solid var(--border-color);">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 45px; height: 45px; border-radius: var(--radius-md); background-color: var(--primary-color); display: flex; align-items: center; justify-content: center; color: #0f172a; font-weight: 900; font-size: 1.2rem; font-family: var(--font-en);">A</div>
                <div>
                    <div style="font-weight: 700; font-size: 0.95rem;">مدیر سیستم</div>
                    <div style="font-size: 0.8rem; color: var(--success); display: flex; align-items: center; gap: 0.3rem;"><div style="width: 8px; height: 8px; background-color: var(--success); border-radius: 50%; box-shadow: 0 0 8px var(--success);"></div> آنلاین</div>
                </div>
            </div>
        </div>
    </aside>

    <div style="flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
        <header style="height: 75px; background-color: rgba(30, 41, 59, 0.8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-color); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; z-index: 5;">
            <div style="position: relative; width: 400px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%);"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" placeholder="جستجو سریع ..." style="width: 100%; background: #0f172a; border: 1px solid var(--border-color); color: var(--text-main); padding: 0.6rem 2.5rem 0.6rem 1rem; border-radius: 20px; font-family: var(--font-fa); outline: none;">
            </div>
        </header>
        <main style="flex-grow: 1; padding: 2rem; overflow-y: auto; overflow-x: hidden;">
            @Body
        </main>
    </div>
</div>

<style>
    .nav-item { display: flex; align-items: center; color: var(--text-muted); text-decoration: none; padding: 0.8rem 1rem; border-radius: var(--radius-md); transition: all 0.2s ease; border: 1px solid transparent; }
    .nav-item:hover { background-color: rgba(56, 189, 248, 0.05); color: var(--text-main); }
    .nav-item.active { background-color: rgba(56, 189, 248, 0.1); color: var(--primary-color); border-color: rgba(56, 189, 248, 0.2); box-shadow: inset 0 0 10px rgba(56, 189, 248, 0.05); }
</style>
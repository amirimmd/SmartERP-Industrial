@page "/"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbFactory

<div>
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem;">
        <div>
            <h1 style="color: var(--text-main); font-weight: 700; font-size: 1.8rem; margin-bottom: 0.5rem;">داشبورد مدیریتی</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.95rem;">نمای کلی وضعیت تولید، انبار و فروش</p>
        </div>
        <div style="color: var(--text-muted); font-family: var(--font-en); font-size: 0.9rem; background: var(--surface-color); padding: 0.5rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
            @DateTime.Now.ToString("yyyy/MM/dd - HH:mm")
        </div>
    </div>

    @if (isLoading)
    {
        <div class="card" style="display: flex; justify-content: center; align-items: center; padding: 4rem;">
            <div class="loader-pulse-ring"></div>
        </div>
    }
    else
    {
        <!-- آمار اصلی -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">

            <div class="card">
                <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 500;">فروش این ماه</h3>
                <div style="display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap;">
                    <span class="industrial-num" style="font-size: 1.8rem; color: var(--primary-color);">@FormatNumber(monthlySales)</span>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">ریال</span>
                </div>
                <div style="margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-muted);">
                    <span style="font-family: var(--font-en); color: var(--text-main);">@monthlyInvoiceCount</span> فاکتور صادر شده
                </div>
            </div>

            <div class="card">
                <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 500;">سفارشات فعال</h3>
                <div style="display: flex; align-items: baseline; gap: 0.5rem;">
                    <span class="industrial-num" style="font-size: 1.8rem; color: var(--accent-color);">@activeInvoiceCount</span>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">سفارش</span>
                </div>
                <div style="margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-muted);">در حال پیگیری و تولید</div>
            </div>

            <div class="card" style="@(lowStockCount > 0 ? "border-color: var(--danger);" : "")">
                <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 500;">هشدار موجودی انبار</h3>
                <div style="display: flex; align-items: baseline; gap: 0.5rem;">
                    <span class="industrial-num" style="font-size: 1.8rem; color: @(lowStockCount > 0 ? "var(--danger)" : "var(--success)");">@lowStockCount</span>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">کالا</span>
                </div>
                <div style="margin-top: 0.75rem; font-size: 0.8rem; color: @(lowStockCount > 0 ? "var(--danger)" : "var(--text-muted)");">
                    @(lowStockCount > 0 ? "نیاز به شارژ فوری!" : "موجودی مطلوب")
                </div>
            </div>

            <div class="card">
                <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 500;">مشتریان CRM</h3>
                <div style="display: flex; align-items: baseline; gap: 0.5rem;">
                    <span class="industrial-num" style="font-size: 1.8rem; color: var(--success);">@totalCustomers</span>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">مشتری</span>
                </div>
                <div style="margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-muted);">ثبت شده در سیستم</div>
            </div>

        </div>

        <!-- هشدار موجودی بحرانی -->
        @if (lowStockProducts.Any())
        {
            <div class="card" style="margin-bottom: 1.5rem; padding: 0; border-color: var(--danger);">
                <div style="padding: 0.75rem 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; gap: 0.5rem;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    <span style="font-size: 0.9rem; font-weight: 700; color: var(--danger);">کالاهای رو به اتمام انبار</span>
                </div>
                <div style="padding: 1rem 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
                    @foreach (var p in lowStockProducts)
                    {
                        <div style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.3); padding: 0.5rem 1rem; border-radius: var(--radius-md); min-width: 160px;">
                            <div style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-en);">@p.Code</div>
                            <div style="font-weight: bold; font-size: 0.85rem; margin: 0.2rem 0;">@p.Name</div>
                            <div style="color: var(--danger); font-family: var(--font-en); font-weight: bold;">@p.StockQuantity <span style="font-family: var(--font-fa); font-size: 0.8rem;">@p.Unit</span></div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- جدول آخرین فاکتورها -->
        <div class="card" style="padding: 0;">
            <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color);">
                <h2 style="font-size: 1.05rem; font-weight: 700;">آخرین فاکتورهای صادر شده</h2>
            </div>
            @if (!recentInvoices.Any())
            {
                <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
                    <p>هنوز فاکتوری ثبت نشده است.</p>
                </div>
            }
            else
            {
                <table class="industrial-table" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="padding: 1rem 1.5rem; text-align: right;">شماره سند</th>
                            <th style="padding: 1rem 1.5rem; text-align: right;">مشتری</th>
                            <th style="padding: 1rem 1.5rem; text-align: right;">وضعیت</th>
                            <th style="padding: 1rem 1.5rem; text-align: right;">مبلغ نهایی (ریال)</th>
                            <th style="padding: 1rem 1.5rem; text-align: right;">تاریخ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in recentInvoices)
                        {
                            <tr class="table-row-hover">
                                <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: var(--primary-color); font-weight: bold;">@inv.InvoiceNumber</td>
                                <td style="padding: 1rem 1.5rem; font-weight: bold;">@inv.CustomerName</td>
                                <td style="padding: 1rem 1.5rem; font-size: 0.9rem;">
                                    @if (inv.Status == "تحویل شده") { <span style="color: var(--accent-color); font-weight: bold;">@inv.Status</span> }
                                    else if (inv.Status == "در حال ارسال") { <span style="color: var(--primary-color); font-weight: bold;">@inv.Status</span> }
                                    else if (inv.Status == "آماده تحویل") { <span style="color: var(--success); font-weight: bold;">@inv.Status</span> }
                                    else { <span style="color: var(--text-muted);">@inv.Status</span> }
                                </td>
                                <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: var(--success); font-weight: bold;">@inv.FinalAmount.ToString("N0")</td>
                                <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: var(--text-muted); font-size: 0.85rem;">@inv.InvoiceDate.ToString("yyyy/MM/dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@code {
    private AppDbContext _db = null!;
    private bool isLoading = true;

    private decimal monthlySales;
    private int monthlyInvoiceCount;
    private int activeInvoiceCount;
    private int lowStockCount;
    private int totalCustomers;
    private List<Invoice> recentInvoices = new();
    private List<Product> lowStockProducts = new();

    protected override async Task OnInitializedAsync()
    {
        _db = await DbFactory.CreateDbContextAsync();
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        try
        {
            var now = DateTime.Now;

            monthlySales = await _db.Invoices
                .Where(i => i.InvoiceDate.Year == now.Year && i.InvoiceDate.Month == now.Month)
                .SumAsync(i => i.FinalAmount);

            monthlyInvoiceCount = await _db.Invoices
                .CountAsync(i => i.InvoiceDate.Year == now.Year && i.InvoiceDate.Month == now.Month);

            activeInvoiceCount = await _db.Invoices
                .CountAsync(i => i.Status != "تحویل شده");

            lowStockCount = await _db.Products
                .CountAsync(p => p.StockQuantity <= 5);

            totalCustomers = await _db.Customers.CountAsync();

            recentInvoices = await _db.Invoices
                .AsNoTracking()
                .OrderByDescending(i => i.Id)
                .Take(8)
                .ToListAsync();

            lowStockProducts = await _db.Products
                .AsNoTracking()
                .Where(p => p.StockQuantity <= 5)
                .OrderBy(p => p.StockQuantity)
                .ToListAsync();
        }
        catch (Exception) { }
        finally { isLoading = false; }
    }

    private string FormatNumber(decimal n)
    {
        if (n >= 1_000_000_000) return $"{n / 1_000_000_000:N1}G";
        if (n >= 1_000_000) return $"{n / 1_000_000:N1}M";
        if (n == 0) return "---";
        return n.ToString("N0");
    }

    public void Dispose() => _db?.Dispose();
}

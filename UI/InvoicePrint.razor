@page "/print/invoice/{Id:int}"
@layout PrintLayout
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using Microsoft.JSInterop
@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

@if (isLoading)
{
    <div style="text-align: center; padding: 5rem; color: #000;">در حال آماده سازی سند چاپی...</div>
}
else if (invoice != null && company != null)
{
    <!-- پیش‌نمایش A4 -->
    <div class="a4-page">
        <!-- هدر فاکتور -->
        <div style="display: flex; justify-content: space-between; border-bottom: 2px solid #000; padding-bottom: 1rem; margin-bottom: 1rem;">
            <div style="flex: 1; text-align: right;">
                <h1 style="font-size: 1.5rem; font-weight: bold; margin: 0 0 0.5rem 0;">@company.CompanyName</h1>
                <p style="font-size: 0.9rem; margin: 0;">@company.Slogan</p>
                <p style="font-size: 0.85rem; margin: 0; color: #555;">تلفن: <span style="font-family: 'JetBrains Mono';">@company.PhoneNumber</span></p>
            </div>
            
            <div style="flex: 1; text-align: center;">
                @if (!string.IsNullOrEmpty(company.LogoPath))
                {
                    <img src="@company.LogoPath" style="max-height: 80px;" />
                }
            </div>

            <div style="flex: 1; text-align: left; font-size: 0.9rem; line-height: 1.6;">
                <p style="margin: 0;">سند: <strong style="font-size: 1.1rem;">@invoice.InvoiceType</strong></p>
                <p style="margin: 0;">شماره: <strong style="font-family: 'JetBrains Mono';">@invoice.InvoiceNumber</strong></p>
                <p style="margin: 0;">تاریخ: <strong style="font-family: 'JetBrains Mono';">@invoice.InvoiceDate.ToString("yyyy/MM/dd")</strong></p>
            </div>
        </div>

        <!-- اطلاعات خریدار و لجستیک -->
        <div style="border: 1px solid #000; border-radius: 4px; margin-bottom: 1.5rem; display: flex;">
            <div style="flex: 1; border-left: 1px solid #000; padding: 0.5rem;">
                <h3 style="font-size: 0.9rem; margin: 0 0 0.5rem 0; border-bottom: 1px dashed #ccc;">مشخصات خریدار</h3>
                <p style="margin: 0 0 0.3rem 0; font-size: 0.85rem;"><strong>نام/شرکت:</strong> @invoice.CustomerName</p>
                <p style="margin: 0 0 0.3rem 0; font-size: 0.85rem;"><strong>تلفن خریدار:</strong> <span style="font-family: 'JetBrains Mono';">@(string.IsNullOrEmpty(invoice.CustomerPhone) ? "---" : invoice.CustomerPhone)</span></p>
                <p style="margin: 0; font-size: 0.85rem;"><strong>محل تحویل:</strong> @(string.IsNullOrEmpty(invoice.DeliveryAddress) ? "---" : invoice.DeliveryAddress)</p>
            </div>
            <div style="flex: 1; padding: 0.5rem;">
                <h3 style="font-size: 0.9rem; margin: 0 0 0.5rem 0; border-bottom: 1px dashed #ccc;">مشخصات باربری و راننده</h3>
                <p style="margin: 0 0 0.3rem 0; font-size: 0.85rem;"><strong>وضعیت کالا:</strong> @invoice.Status</p>
                <p style="margin: 0 0 0.3rem 0; font-size: 0.85rem;"><strong>نام راننده:</strong> @(string.IsNullOrEmpty(invoice.DriverName) ? "تعیین نشده" : invoice.DriverName)</p>
                <p style="margin: 0; font-size: 0.85rem;"><strong>پلاک خودرو:</strong> <span style="font-family: 'JetBrains Mono';">@(string.IsNullOrEmpty(invoice.VehiclePlate) ? "---" : invoice.VehiclePlate)</span></p>
            </div>
        </div>

        <!-- جدول اقلام -->
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; text-align: center;">
            <thead>
                <tr style="background-color: #f3f4f6; border: 1px solid #000;">
                    <th style="padding: 0.5rem; border: 1px solid #000; width: 5%;">ردیف</th>
                    <th style="padding: 0.5rem; border: 1px solid #000; text-align: right;">شرح کالا</th>
                    <th style="padding: 0.5rem; border: 1px solid #000; width: 10%;">تعداد</th>
                    <th style="padding: 0.5rem; border: 1px solid #000; width: 20%;">فی (ریال)</th>
                    <th style="padding: 0.5rem; border: 1px solid #000; width: 25%;">مبلغ کل (ریال)</th>
                </tr>
            </thead>
            <tbody>
                @{ int row = 1; }
                @foreach (var item in items)
                {
                    <tr>
                        <td style="padding: 0.5rem; border: 1px solid #000; font-family: 'JetBrains Mono';">@row</td>
                        <td style="padding: 0.5rem; border: 1px solid #000; text-align: right; font-weight: bold;">@item.ProductName</td>
                        <td style="padding: 0.5rem; border: 1px solid #000; font-family: 'JetBrains Mono';">@item.Quantity</td>
                        <td style="padding: 0.5rem; border: 1px solid #000; font-family: 'JetBrains Mono';">@item.UnitPrice.ToString("N0")</td>
                        <td style="padding: 0.5rem; border: 1px solid #000; font-family: 'JetBrains Mono'; font-weight: bold;">@((item.UnitPrice * (decimal)item.Quantity).ToString("N0"))</td>
                    </tr>
                    row++;
                }
            </tbody>
        </table>

        <!-- اطلاعات پرداخت و حساب بانکی -->
        <div style="border: 2px solid #000; border-radius: 4px; margin-bottom: 1.5rem; display: flex;">
            <div style="flex: 1; border-left: 1px solid #000; padding: 0.5rem; background-color: #fafafa;">
                <h3 style="font-size: 0.9rem; margin: 0 0 0.5rem 0; border-bottom: 1px dashed #ccc;">نحوه تسویه حساب: <strong style="font-size: 1rem;">@invoice.PaymentMethod</strong></h3>
                <div style="display: flex; gap: 1rem; margin-bottom: 0.3rem;">
                    <p style="margin: 0; font-size: 0.85rem;"><strong>نقدی:</strong> <span style="font-family: 'JetBrains Mono';">@invoice.CashAmount.ToString("N0")</span> ریال</p>
                    <p style="margin: 0; font-size: 0.85rem;"><strong>چکی:</strong> <span style="font-family: 'JetBrains Mono';">@invoice.CheckAmount.ToString("N0")</span> ریال</p>
                </div>
                @if (!string.IsNullOrEmpty(invoice.CheckDetails))
                {
                    <p style="margin: 0; font-size: 0.85rem;"><strong>مشخصات چک:</strong> @invoice.CheckDetails</p>
                }
            </div>
            
            <!-- کادر جمع کل -->
            <div style="width: 300px; padding: 0.5rem; display: flex; flex-direction: column; justify-content: center;">
                <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed #000; padding-bottom: 0.3rem; margin-bottom: 0.3rem; font-size: 0.9rem;">
                    <span>جمع اقلام:</span>
                    <span style="font-family: 'JetBrains Mono';">@invoice.TotalAmount.ToString("N0")</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.2rem;">
                    <span>مبلغ نهایی:</span>
                    <span style="font-family: 'JetBrains Mono';">@invoice.FinalAmount.ToString("N0") ریال</span>
                </div>
            </div>
        </div>

        <!-- حساب بانکی فروشنده -->
        <div style="border: 1px dashed #000; padding: 0.5rem; margin-bottom: 1.5rem; text-align: center; font-size: 0.85rem; border-radius: 4px;">
            <strong>شماره حساب واریزی (@company.BankName):</strong> 
            شماره کارت <span style="font-family: 'JetBrains Mono';">@company.AccountNumber</span> | 
            شبا: <span style="font-family: 'JetBrains Mono';">@company.ShabaNumber</span> | 
            به نام: <strong>@company.CardOwner</strong>
        </div>

        <!-- فوتر و امضاها -->
        <div style="display: flex; justify-content: space-between; border-top: 1px solid #000; padding-top: 2rem; margin-top: auto;">
            <div style="text-align: center; flex: 1;">
                <p style="font-weight: bold; margin-bottom: 3rem;">مهر و امضای فروشنده</p>
                <p style="font-size: 0.8rem; color: #555;">واحد مالی / حسابداری</p>
            </div>
            <div style="text-align: center; flex: 1;">
                <p style="font-weight: bold; margin-bottom: 3rem;">امضای راننده / باربری</p>
                <p style="font-size: 0.8rem; color: #555;">تاییدیه سلامت بار در مبدا</p>
            </div>
            <div style="text-align: center; flex: 1;">
                <p style="font-weight: bold; margin-bottom: 3rem;">مهر و امضای خریدار</p>
                <p style="font-size: 0.8rem; color: #555;">تاییدیه دریافت کامل و سالم کالا</p>
            </div>
        </div>

        <div style="text-align: center; font-size: 0.75rem; border-top: 1px dashed #ccc; padding-top: 0.5rem; margin-top: 2rem;">
            آدرس کارخانه: @company.Address
        </div>
    </div>

    <!-- دکمه‌های کنترل مانیتور (در پرینت مخفی می‌شوند) -->
    <div class="no-print" style="position: fixed; bottom: 20px; right: 20px; display: flex; gap: 10px;">
        <button onclick="@(async () => await JSRuntime.InvokeVoidAsync("window.print"))" style="background-color: #f59e0b; color: #000; padding: 10px 20px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-family: 'Vazirmatn'; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">🖨️ فرمان چاپ روی برگه A4</button>
        <button @onclick="GoBack" style="background-color: #374151; color: #fff; padding: 10px 20px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-family: 'Vazirmatn';">بازگشت</button>
    </div>
}

<style>
    .a4-page {
        width: 210mm;
        min-height: 297mm;
        margin: 10mm auto;
        background: white;
        padding: 15mm;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
    }
    @@media print {
        .a4-page { margin: 0; box-shadow: none; border: none; width: auto; min-height: auto; padding: 0; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    
    private Invoice? invoice;
    private CompanySetting? company;
    private bool isLoading = true;
    
    private class TempItem { 
        public string ProductName { get; set; } = string.Empty;
        public double Quantity { get; set; } 
        public decimal UnitPrice { get; set; } 
    }
    private List<TempItem> items = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.Yield();
        try
        {
            invoice = await DbContext.Invoices.FirstOrDefaultAsync(i => i.Id == Id);
            company = await DbContext.CompanySettings.FirstOrDefaultAsync();
            if (invoice != null && !string.IsNullOrEmpty(invoice.ItemsJson))
            {
                items = JsonSerializer.Deserialize<List<TempItem>>(invoice.ItemsJson) ?? new();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/invoices");
    }
}
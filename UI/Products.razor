@page "/products"
@using SmartERP.Core
@using SmartERP.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext

<div class="module-header">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
        <div>
            <h1 style="color: var(--primary-color); font-weight: 800; font-size: 1.8rem; margin-bottom: 0.5rem;">انبار و محصولات</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.95rem;">مدیریت موجودی قطعات و کاتالوگ فروش</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">ثبت کالای جدید</button>
    </div>

    <div class="card" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; display: flex; gap: 1rem; align-items: center;">
        <div style="position: relative; flex-grow: 1;">
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="جستجوی سریع قطعات ..." class="input-field" style="margin-bottom: 0; border-radius: 20px;" />
        </div>
        <div style="color: var(--text-muted); font-size: 0.9rem; font-weight: bold;">
            کل قطعات: <span style="color: var(--primary-color); font-family: var(--font-en);">@filteredProducts.Count</span>
        </div>
    </div>

    <div class="card" style="padding: 0; overflow-x: auto;">
        <table class="industrial-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="padding: 1.2rem 1.5rem; text-align: right;">کد قطعه</th>
                    <th style="padding: 1.2rem 1.5rem; text-align: right;">شرح کالا</th>
                    <th style="padding: 1.2rem 1.5rem; text-align: right;">موجودی</th>
                    <th style="padding: 1.2rem 1.5rem; text-align: right;">قیمت پایه (ریال)</th>
                    <th style="padding: 1.2rem 1.5rem; text-align: center;">ویرایش</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="5" style="padding: 3rem; text-align: center;"><div class="loader-pulse-ring" style="margin: 0 auto;"></div></td></tr>
                }
                else if (!filteredProducts.Any())
                {
                    <tr><td colspan="5" style="padding: 4rem 2rem; text-align: center; color: var(--text-muted);"><p>موجودی یافت نشد.</p></td></tr>
                }
                else
                {
                    @foreach (var product in filteredProducts)
                    {
                        <tr class="table-row-hover">
                            <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: var(--primary-color); font-weight: bold;">@product.Code</td>
                            <td style="padding: 1rem 1.5rem; font-weight: bold; color: var(--text-main);">@product.Name</td>
                            <td style="padding: 1rem 1.5rem; font-family: var(--font-en); color: @(product.StockQuantity <= 5 ? "var(--danger)" : "var(--success)"); font-weight: bold;">@product.StockQuantity <span style="font-size: 0.8rem; color: var(--text-muted); font-family: var(--font-fa);">@product.Unit</span></td>
                            <td style="padding: 1rem 1.5rem; font-family: var(--font-en);">@product.Price.ToString("N0")</td>
                            <td style="padding: 1rem 1.5rem; text-align: center;">
                                <button style="background: none; border: none; color: var(--accent-color); cursor: pointer; padding: 0.5rem;" @onclick="() => OpenEditModal(product)">ویرایش</button>
                                <button style="background: none; border: none; color: var(--danger); cursor: pointer; padding: 0.5rem;" @onclick="() => DeleteProduct(product)">حذف</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (isModalOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(9, 9, 11, 0.9); z-index: 100; display: flex; align-items: center; justify-content: center;">
        <div class="card" style="width: 100%; max-width: 500px; border-top: 3px solid var(--primary-color);">
            <div style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
                <h2 style="font-size: 1.2rem; color: var(--text-main); font-weight: 800;">@(editingProduct.Id == 0 ? "ثبت کالای جدید" : "ویرایش کالا")</h2>
            </div>

            <div class="form-group">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">کد قطعه / سریال</label>
                <input type="text" @bind="editingProduct.Code" class="input-field" style="font-family: var(--font-en);" />
            </div>

            <div class="form-group">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">نام کالا</label>
                <input type="text" @bind="editingProduct.Name" class="input-field" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">موجودی اولیه</label>
                    <input type="number" @bind="editingProduct.StockQuantity" class="input-field" style="font-family: var(--font-en);" />
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">واحد شمارش</label>
                    <input type="text" @bind="editingProduct.Unit" class="input-field" />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 2rem;">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted);">قیمت پایه (ریال)</label>
                <input type="number" @bind="editingProduct.Price" class="input-field" style="font-family: var(--font-en);" />
            </div>

            <div style="display: flex; gap: 1rem;">
                <button class="btn-primary" style="flex: 1;" @onclick="SaveProduct">ذخیره کالا</button>
                <button style="flex: 1; background: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-main); border-radius: var(--radius-md); cursor: pointer; font-weight: bold;" @onclick="CloseModal">انصراف</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Product> products = new();
    private List<Product> filteredProducts = new();
    private bool isLoading = true;
    private string _searchQuery = "";
    private bool isModalOpen = false;
    private Product editingProduct = new();

    private string searchQuery { get => _searchQuery; set { _searchQuery = value; FilterProducts(); } }

    protected override async Task OnInitializedAsync()
    {
        // 🚀 سرعت بالا: بدون چک کردن دیتابیس
        await Task.Yield();
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        try { products = await DbContext.Products.AsNoTracking().ToListAsync(); filteredProducts = products.ToList(); }
        finally { isLoading = false; }
    }

    private void FilterProducts()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) { filteredProducts = products.ToList(); }
        else { var q = searchQuery.ToLower(); filteredProducts = products.Where(p => (p.Name != null && p.Name.ToLower().Contains(q)) || (p.Code != null && p.Code.ToLower().Contains(q))).ToList(); }
    }

    private void OpenAddModal() { editingProduct = new Product { Unit = "عدد" }; isModalOpen = true; }
    private void OpenEditModal(Product p) { editingProduct = new Product { Id = p.Id, Code = p.Code, Name = p.Name, Price = p.Price, StockQuantity = p.StockQuantity, Unit = p.Unit }; isModalOpen = true; }
    private void CloseModal() { isModalOpen = false; }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(editingProduct.Name) || string.IsNullOrWhiteSpace(editingProduct.Code)) return;
        try
        {
            if (editingProduct.Id == 0) DbContext.Products.Add(editingProduct); else DbContext.Products.Update(editingProduct);
            await DbContext.SaveChangesAsync(); await LoadProducts(); CloseModal();
        }
        catch (Exception) { }
    }

    private async Task DeleteProduct(Product p)
    {
        try { DbContext.Products.Remove(p); await DbContext.SaveChangesAsync(); await LoadProducts(); } catch (Exception) { }
    }
}
<Window x:Class="SmartERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:components="clr-namespace:SmartERP.Components;assembly=SmartERP"
        mc:Ignorable="d"
        Title="SmartERP - Industrial"
        Height="768"
        Width="1366"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Background="#0f172a">
    <Grid>
        <!--
            BlazorWebView hosts the entire Blazor application.
            HostPage  → the static HTML shell (wwwroot\index.html).
            Selector  → the CSS selector of the <div> in index.html that
                        Blazor will mount the root component into (#app).
            ComponentType → SmartERP.Components.Routes (the Blazor router).
            Services  → supplied from code-behind after the DI container is built.
        -->
        <blazor:BlazorWebView x:Name="blazorWebView"
                              HostPage="wwwroot\index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app"
                                      ComponentType="{x:Type components:Routes}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>

@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.JSInterop

@* EF Core *@
@using Microsoft.EntityFrameworkCore

@* SmartERP namespaces — all files keep their original namespace declarations *@
@using SmartERP
@using SmartERP.Core
@using SmartERP.Infrastructure
@using SmartERP.UI
@using SmartERP.Helpers
@using SmartERP.Components
